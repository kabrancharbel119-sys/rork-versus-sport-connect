# =============================================================================
# VS Sport Connect - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer le fichier .env (il est dans .gitignore).
# =============================================================================

# --- Supabase (obligatoire pour l'app) ---
EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# --- API / Backend (obligatoire si l'app utilise le backend Rork / tRPC) ---
EXPO_PUBLIC_RORK_API_BASE_URL=http://localhost:3000

# --- Auth sécurisée (recommandé en production) ---
# Mettre 'true' pour que login/register passent par le backend (pas de password_hash côté client).
# Le backend doit avoir SUPABASE_URL et SUPABASE_SERVICE_ROLE_KEY.
EXPO_PUBLIC_USE_BACKEND_AUTH=false

# --- Backend uniquement (sur le serveur qui exécute backend/hono) ---
# Supabase service role : utilisé pour l’auth backend (login/register). À garder secret.
# SUPABASE_URL=https://votre-projet.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# --- Email (Resend, utilisé par le backend pour vérification / reset mot de passe) ---
# RESEND_API_KEY=re_xxxx

# --- CORS (backend uniquement, optionnel) ---
# En production, limiter les origines : https://votredomaine.com,https://app.votredomaine.com
# ALLOWED_ORIGINS=https://votredomaine.com

# --- Sentry (crash reporting, optionnel) ---
# Créer un projet sur sentry.io et coller le DSN ici pour les builds production.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
